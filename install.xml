<?xml version="1.0" encoding="utf-8"?>
<modification>
    <name>Vindi Pagamentos</name>
	<code>Vindi Pagamentos</code>
	<version>1.0.0.0</version>
	<author>Opencart Master</author>
	<link>https://opencartmaster.com.br</link>
	
	<file path="catalog/controller/checkout/success.php">
		<operation error="skip">
        <search trim="true"><![CDATA[unset($this->session->data['shipping_method']);]]></search>
		<add position="before"><![CDATA[
        if ($this->session->data['payment_method']['code'] == 'vindiboleto' || $this->session->data['payment_method']['code'] == 'vindipix') {
        $oid = $this->session->data['order_id'];
        $data['meupedido'] = $oid;
        $data['tipopay'] = $this->session->data['payment_method']['code'];
        $this->load->model('account/order');

        $order_info = $this->model_account_order->getOrder($oid);
        } 
        ]]></add>
		</operation>
        <operation error="skip">
        <search trim="true"><![CDATA[if ($this->customer->isLogged()) {]]></search>
		<add position="replace"><![CDATA[
        $data['text_message'] = "teste de msg <br>";
        if ($this->customer->isLogged()) {
			$data['text_message'] .= sprintf($this->language->get('text_customer'), $this->url->link('account/account', '', true), $this->url->link('account/order', '', true), $this->url->link('account/download', '', true), $this->url->link('information/contact'));
		} else {
			$data['text_message'] .= sprintf($this->language->get('text_guest'), $this->url->link('information/contact'));
		}
		]]></add>
		</operation>
	</file>
	
	<file path="catalog/view/theme/*/template/common/header.twig">
		<operation error="skip">
        <search trim="true"><![CDATA[</head>]]></search>
		<add position="before"><![CDATA[<script src="https://static.traycheckout.com.br/js/finger_print.js" type="text/javascript">
    
		]]></add>
		</operation>
	</file>
	
</modification>